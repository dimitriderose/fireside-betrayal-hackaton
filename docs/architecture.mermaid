graph TB
    subgraph Players["Player Phones (2-7)"]
        P1["Player 1<br/>Mobile Browser<br/>AudioWorklet Mic Capture"]
        P2["Player 2<br/>Mobile Browser<br/>AudioWorklet Mic Capture"]
        P3["Player N<br/>Mobile Browser"]
        FE_STATE["Frontend State<br/>aiCharacters: [] array<br/>(variable-count AI chars)"]
        PTT["Push-to-Talk<br/>Speaker Lock<br/>(one active speaker at a time)"]
    end

    subgraph CloudRun["Google Cloud Run"]
        API["FastAPI Backend<br/>Port 8000"]
        DT["Discussion Timer<br/>Dynamic Timeout<br/>120s / 180s / 240s<br/>30s Warning Task"]

        subgraph Agents["AI Agents"]
            NA["Narrator Agent<br/>Gemini Live API<br/>Voice + Affective Dialog<br/>4 Presets: Classic/Campfire/Horror/Comedy<br/>Dual-Mode: Theatrical + Moderator"]
            subgraph AIFuncs["traitor_agent.py — Unified AI Functions"]
                TRIGGER["Trigger Functions<br/>trigger_all_night_actions()<br/>trigger_all_votes()<br/>trigger_all_dialogs()<br/>asyncio.gather parallel exec"]
                INDIV["Individual AI Functions<br/>generate_dialog()<br/>select_night_target()<br/>select_vote()<br/>select_loyal_night_action()<br/>Loops via _ai_chars_with_fields()"]
            end
            GM["Game Master<br/>Deterministic Python<br/>Role Assignment + Phase Transitions<br/>Win Conditions (parity) + Vote Resolution<br/>Human Shapeshifter Support<br/>_resolving_nights guard"]
            SA["Scene Agent<br/>Image Generation<br/>Phase Transition Illustrations"]
            CV["Camera Vote Agent<br/>Gemini Vision<br/>Hand-Counting (In-Person)"]
            AR["Audio Recorder<br/>Highlight Reel<br/>Post-Game Playback"]
            SL["Strategy Logger<br/>Cross-Game Learning<br/>Intelligence Brief"]
        subgraph GhostSystem["Ghost Council / Séance (v5.1)"]
                GC["Ghost Council<br/>Dead Player Chat<br/>ghost_message WS type<br/>2s rate limit per player"]
                SEANCE["Séance Phase<br/>Triggered: dead >= 2 AND<br/>dead >= total/2<br/>45s ghost push-to-talk"]
                HAUNT["Haunt Actions<br/>Dead player night accusation<br/>AI ghost auto-accuse<br/>Narrator incorporates"]
            end

            AIREPLY["AI Auto-Reply<br/>_maybe_trigger_ai_reply()<br/>Name-match regex (≥3 chars)<br/>30s cooldown per character"]
        end

        subgraph VoicePipeline["Player Voice Input Pipeline (Audio WS only)"]
            AWS["Audio WS Handler<br/>/ws/audio/{game_id}<br/>Binary PCM frames<br/>Speaker lock enforced"]
            DECODE["Binary PCM Decode<br/>+ Speaker Lookup"]
            SPKR["Speaker Identification<br/>Character Name Annotation<br/>end_of_turn=False"]
            TBUF["Transcript Buffer<br/>0.8s Debounce Flush"]
        end
    end

    subgraph GCP["Google Cloud Platform"]
        FS[("Cloud Firestore<br/>Real-time Game State<br/>Players, Events, Chat")]
    end

    subgraph Gemini["Google Gemini API"]
        GLive["Gemini Live API<br/>WebSocket<br/>Bidirectional Voice + Transcription"]
        GFlash["gemini-2.5-flash<br/>Text Strategy"]
        GTTS["gemini-2.5-flash-preview-tts<br/>Narrator Previews"]
    end

    subgraph Infra["Infrastructure"]
        TF["Terraform IaC<br/>Cloud Run + Firestore<br/>Artifact Registry + IAM"]
        DOCK["Multi-Stage Dockerfile<br/>node:18-slim -> python:3.11-slim"]
    end

    %% Player connections — two separate WebSocket paths per player
    P1 <-->|"WS /ws/{game_id}<br/>game state · chat · votes · phase changes"| API
    P2 <-->|"WS /ws/{game_id}<br/>game state · chat · votes · phase changes"| API
    P3 <-->|"REST /api/*"| API

    %% Audio WebSocket — separate connection, binary PCM only
    P1 -.->|"WS /ws/audio/{game_id}<br/>binary PCM16 16kHz frames<br/>(push-to-talk, speaker lock)"| AWS
    P2 -.->|"WS /ws/audio/{game_id}<br/>binary PCM16 16kHz frames<br/>(push-to-talk, speaker lock)"| AWS
    PTT -.->|"grants / revokes<br/>speaker lock"| AWS

    %% Voice input flow: Audio WS -> Decode -> Speaker ID -> Narrator only
    AWS -->|"raw PCM bytes + player_id"| DECODE
    DECODE -->|"PCM bytes + character_name"| SPKR
    SPKR -->|"[VOICE] Speaker annotation<br/>+ raw PCM"| NA

    %% Transcript flow: Gemini -> Buffer -> Broadcast
    GLive -.->|"input_audio_transcription<br/>partial fragments"| TBUF
    TBUF -.->|"input_transcript broadcast<br/>speaker + buffered sentence"| API

    %% Agent connections
    API --> NA
    API --> GM
    API --> SA
    API --> CV
    API --> AR
    API --> SL
    API --> DT

    %% Unified AI function flow
    GM -->|"night/vote/discussion phases"| TRIGGER
    API -->|"ws_router calls"| TRIGGER
    NA -->|"narrator triggers"| TRIGGER
    TRIGGER -->|"asyncio.gather<br/>parallel per AI char"| INDIV

    %% Gemini connections
    NA <-->|"Bidirectional Voice<br/>+ Speaker Annotations"| GLive
    INDIV -->|"Text Completions<br/>all AI characters"| GFlash
    NA -->|"Audio Previews"| GTTS
    SA -->|"Image Gen"| GFlash
    CV -->|"Vision Analysis"| GFlash

    %% Data connections
    GM --> FS
    SL --> FS
    API --> FS
    DECODE -.->|"character_name lookup"| FS

    %% Ghost Council / Séance connections
    GC -->|"ghost_message broadcast"| API
    GC -->|"stored in chat collection"| FS
    SEANCE -->|"re-enables dead player PTT"| PTT
    SEANCE -->|"narrator moderates testimony"| NA
    HAUNT -->|"haunt_action events"| FS
    HAUNT -->|"narrator incorporates in discussion"| NA
    GM -->|"séance trigger check<br/>dead >= 2 AND dead >= total/2"| SEANCE

    %% AI Auto-Reply connections
    TBUF -->|"transcript flush triggers"| AIREPLY
    AIREPLY -->|"generate dialog"| GFlash
    AIREPLY -->|"broadcast as source=player"| API

    %% Discussion timer connections
    DT -->|"wrap-up prompt at T-30s"| NA
    DT -->|"timer_seconds in phase_change"| API

    %% Infrastructure provisions Cloud Run
    TF -.->|"provisions"| CloudRun
    TF -.->|"provisions"| FS
    DOCK -.->|"builds"| CloudRun

    classDef player fill:#1a1a2e,stroke:#e94560,color:#fff
    classDef cloud fill:#0f3460,stroke:#16213e,color:#fff
    classDef agent fill:#533483,stroke:#e94560,color:#fff
    classDef gcp fill:#4285f4,stroke:#1a73e8,color:#fff
    classDef gemini fill:#1e88e5,stroke:#1565c0,color:#fff
    classDef voice fill:#2d6a4f,stroke:#40916c,color:#fff
    classDef infra fill:#374151,stroke:#6b7280,color:#fff
    classDef timer fill:#92400e,stroke:#d97706,color:#fff
    classDef ghost fill:#4a1942,stroke:#9b59b6,color:#fff

    class P1,P2,P3,FE_STATE,PTT player
    class API cloud
    class NA,TRIGGER,INDIV,GM,SA,CV,AR,SL,AIREPLY agent
    class FS gcp
    class GLive,GFlash,GTTS gemini
    class AWS,DECODE,SPKR,TBUF voice
    class TF,DOCK infra
    class DT timer
    class GC,SEANCE,HAUNT ghost
